#include <iostream>
#include <cmath>

using namespace std;

const int ROWS = 5;
const int COLS = 5;

int main() {
    int matrix[ROWS][COLS];
    int i, j, d;
    int sumDivisibleBy5;
    long long columnProducts[COLS];

    setlocale(LC_ALL, "en_US.UTF-8");

    cout << "Enter matrix elements:\n";
    for (i = 0; i < ROWS; i++) {
        for (j = 0; j < COLS; j++) {
            cout << "Enter array element [" << i << "][" << j << "]: ";
            cin >> matrix[i][j];
        }
    }

    sumDivisibleBy5 = 0;
    for (i = 0; i < ROWS; i++) {
        for (j = 0; j < COLS; j++) {
            if (matrix[i][j] % 5 == 0) {
                sumDivisibleBy5 += matrix[i][j];
            }
        }
    }
    cout << "\nSum of elements divisible by 5 = " << sumDivisibleBy5 << "\n";

    cout << "Divisors of this sum: ";
    if (sumDivisibleBy5 == 0) {
        cout << "all integers (sum = 0)\n";
    }
    else {
        for (d = 1; d <= abs(sumDivisibleBy5); d++) {
            if (sumDivisibleBy5 % d == 0) {
                cout << d << " ";
            }
        }
        cout << "\n";
    }

    for (j = 0; j < COLS; j++) {
        columnProducts[j] = 1;
    }

    for (j = 0; j < COLS; j++) {
        for (i = 0; i < ROWS; i++) {
            columnProducts[j] *= matrix[i][j];
        }
    }

    cout << "Column products (1D array):\n";
    for (j = 0; j < COLS; j++) {
        cout << columnProducts[j] << "\t";
    }
    cout << "\n";

    return 0;
}
