#include <iostream>
#include <vector>
using namespace std;

int main() {
    int n, m;
    cout << "Enter rows and columns: ";
    cin >> n >> m;

    vector<vector<int>> a(n, vector<int>(m));

    cout << "Enter matrix elements:\n";
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            cin >> a[i][j];
        }
    }

    int sum = 0;
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            if (a[i][j] % 5 == 0)
                sum += a[i][j];
        }
    }

    cout << "Sum of elements divisible by 5 = " << sum << "\n";

    cout << "Divisors of this sum: ";
    if (sum == 0) {
        cout << "all integers (sum = 0)\n";
    }
    else {
        for (int d = 1; d <= abs(sum); d++) {
            if (sum % d == 0)
                cout << d << " ";
        }
        cout << "\n";
    }

    vector<long long> colProd(m, 1);

    for (int j = 0; j < m; j++) {
        for (int i = 0; i < n; i++) {
            colProd[j] *= a[i][j];
        }
    }

    cout << "Column products: ";
    for (long long x : colProd)
        cout << x << " ";
    cout << "\n";

    return 0;
}
